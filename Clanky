CREATE DATABASE ClankyDB;
USE ClankyDB;

CREATE TABLE Clanek (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nadpis VARCHAR(255) NOT NULL,
    perex TEXT,
    obsah TEXT NOT NULL,
    datum_vytvoreni DATETIME DEFAULT CURRENT_TIMESTAMP,
    datum_upravy DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

CREATE TABLE Kategorie (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nazev VARCHAR(100) NOT NULL UNIQUE
);

CREATE TABLE Clanek_Kategorie (
    clanek_id INT,
    kategorie_id INT,
    PRIMARY KEY (clanek_id, kategorie_id),
    FOREIGN KEY (clanek_id) REFERENCES Clanek(id) ON DELETE CASCADE,
    FOREIGN KEY (kategorie_id) REFERENCES Kategorie(id) ON DELETE CASCADE
);

CREATE TABLE Galerie (
    id INT AUTO_INCREMENT PRIMARY KEY,
    clanek_id INT,
    obrazek_url VARCHAR(255) NOT NULL,
    FOREIGN KEY (clanek_id) REFERENCES Clanek(id) ON DELETE CASCADE
);

CREATE TABLE Soubor (
    id INT AUTO_INCREMENT PRIMARY KEY,
    clanek_id INT,
    soubor_url VARCHAR(255) NOT NULL,
    FOREIGN KEY (clanek_id) REFERENCES Clanek(id) ON DELETE CASCADE
);

CREATE TABLE Clanek_Vazba (
    id INT AUTO_INCREMENT PRIMARY KEY,
    zdroj_clanek_id INT,
    cilovy_clanek_id INT,
    FOREIGN KEY (zdroj_clanek_id) REFERENCES Clanek(id) ON DELETE CASCADE,
    FOREIGN KEY (cilovy_clanek_id) REFERENCES Clanek(id) ON DELETE CASCADE
);
